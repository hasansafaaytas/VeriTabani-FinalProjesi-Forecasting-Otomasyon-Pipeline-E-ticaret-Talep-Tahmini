    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let item = $input.item.json;\n\nif (item.Satilan_Adet === null || item.Satilan_Adet === undefined || item.Satilan_Adet === \"\") {\n    item.Satilan_Adet = 0;\n} else {\n    item.Satilan_Adet = Number(item.Satilan_Adet);\n}\n\nif (item.Mevcut_Stok === null || item.Mevcut_Stok === undefined || item.Mevcut_Stok === \"\") {\n    item.Mevcut_Stok = 0;\n} else {\n    item.Mevcut_Stok = Number(item.Mevcut_Stok);\n}\n\nif (item.Urun_Adi === null || item.Urun_Adi === undefined || item.Urun_Adi.trim() === \"\") {\n    item.Urun_Adi = \"Bilinmeyen Ürün\";\n}\nreturn { json: item };"
      },
