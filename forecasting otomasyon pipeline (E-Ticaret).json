      "parameters": {
        "jsCode": "const aiText = $input.first().json.content.parts[0].text;\n\nconst cleanText = aiText.replace(/```json/gi, \"\").replace(/```/g, \"\").trim();\n\nconst parsedData = JSON.parse(cleanText);\nreturn parsedData.map(item => ({ json: item }));"
      },
