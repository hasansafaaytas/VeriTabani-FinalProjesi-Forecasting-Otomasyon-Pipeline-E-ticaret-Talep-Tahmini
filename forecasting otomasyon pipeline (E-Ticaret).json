    {
      "parameters": {
        "jsCode": "const currentSales = $input.item.json[\"Input 2\"] || $input.all().map(item => item.json);\nconst oldPredictions = $input.item.json[\"Input 1\"] || $(\"Eski Tahminleri Çekme\").all().map(item => item.json);\n\nlet degerlendirmeNotu = \"Henüz geçmiş tahmin verisi bulunmuyor, ilk tahmininizi yapıyorsunuz.\";\n\nif (oldPredictions.length > 0) {\n    let toplamMape = 0;\n    let eslesenUrunSayisi = 0;\n    let raporDetayi = [];\n\n    oldPredictions.forEach(pred => {\n        const urunSatislari = currentSales\n            .filter(sale => sale.Urun_Adi === pred.Urun_Adi)\n            .sort((a, b) => new Date(a.Tarih) - new Date(b.Tarih))\n            .slice(-7); \n        \n        if (urunSatislari.length > 0) {\n            const gerceklesenSatis = urunSatislari.reduce((sum, current) => sum + Number(current.Satilan_Adet || 0), 0);\n            const eskiTahmin = Number(pred.Tahmini_Satis_7Gun || 0);\n\n            if (gerceklesenSatis > 0) {\n                const mutlakHata = Math.abs(gerceklesenSatis - eskiTahmin);\n                const mape = (mutlakHata / gerceklesenSatis) * 100;\n                \n                toplamMape += mape;\n                eslesenUrunSayisi++;\n\n                const yonelim = eskiTahmin > gerceklesenSatis ? \"Aşırı Tahmin (Over-forecast)\" : \"Eksik Tahmin (Under-forecast)\";\n                raporDetayi.push(`${pred.Urun_Adi} için tahmin hatası (MAPE): %${mape.toFixed(1)} (${yonelim}).`);\n            }\n        }\n    });\n\n    if (eslesenUrunSayisi > 0) {\n        const ortalamaMape = toplamMape / eslesenUrunSayisi;\n        const genelDogruluk = 100 - ortalamaMape;\n        degerlendirmeNotu = `Geçen haftaki genel tahmin doğruluk oranınız: %${genelDogruluk.toFixed(1)}. Ortalama Hata (MAPE): %${ortalamaMape.toFixed(1)}. Detaylar: ${raporDetayi.join(\" \")}`;\n    }\n}\n\nreturn {\n    json: {\n        degerlendirme_raporu: degerlendirmeNotu,\n        clean_data: JSON.stringify(currentSales, null, 2)\n    }\n};"
      },
